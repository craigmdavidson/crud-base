<%= link_to "Edit", edit_post_path(@post), class: "link float-right" %>
<h1 class="text-4xl"><%= @post.title %></h1>


<p class="mt-4 text-base-content/80"><%= @post.body %></p>



<h2 class="text-2xl mt-8">Comments</h2>
<%= link_to "Add comment", new_post_comment_path(@post), class: "link" %>

<div class="mt-2">
<% @post.comments.each do |comment| %>
  <%= render comment %>
<% end %>
</div>
