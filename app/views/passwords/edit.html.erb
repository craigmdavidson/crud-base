<div class="grid h-screen place-items-center bg-gray-50">
  <div class="w-full max-w-sm border border-gray-200 bg-white shadow-sm rounded-lg p-8">
    <% if alert = flash[:alert] %>
      <p class="text-red-600 font-light italic text-sm mb-4" id="alert"><%= alert %></p>
    <% end %>

    <h1 class="text-2xl font-bold text-gray-900 mb-6">Reset password</h1>

    <%= form_with url: password_path(params[:token]), method: :put, class: "space-y-4" do |form| %>
      <div class="fieldset">
        <%= form.label :password, "New password", class: "block mb-1 text-sm font-medium text-gray-700" %>
        <%= form.password_field :password, required: true, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <div class="fieldset">
        <%= form.label :password_confirmation, "Confirm password", class: "block mb-1 text-sm font-medium text-gray-700" %>
        <%= form.password_field :password_confirmation, required: true, autocomplete: "new-password", maxlength: 72, class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" %>
      </div>

      <%= form.submit "Reset password", class: "w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 cursor-pointer mt-2" %>
    <% end %>
  </div>
</div>
