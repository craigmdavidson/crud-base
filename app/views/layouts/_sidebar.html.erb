<aside id="default-sidebar" data-sidebar-target="sidebar" class="fixed top-0 left-0 z-40 w-64 h-screen pt-16 transition-transform -translate-x-full sm:translate-x-0 bg-base-100 border-r border-base-200" aria-label="Sidenav">
  <div class="overflow-y-auto py-5 px-3 h-full">
    <ul class="menu">
      <% AutoController.sidebar_controllers.each do |ctrl| %>
        <li>
          <%= link_to url_for(controller: "/#{ctrl.controller_path}", action: :index), class: (ctrl.controller_path == controller.controller_path ? "menu-active" : nil) do %>
            <svg aria-hidden="true" class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd"></path></svg>
            <%= ctrl.model.model_name.human.pluralize %>
          <% end %>
        </li>
      <% end %>
    </ul>
  </div>
</aside>
