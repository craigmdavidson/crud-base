<header class="navbar bg-base-100/80 backdrop-blur-sm border-b border-base-200 sticky top-0 z-50 px-4">
  <div class="navbar-start">
    <button data-action="sidebar#toggle" type="button" class="btn btn-ghost sm:hidden" aria-label="Open sidebar">
      <svg class="w-5 h-5" aria-hidden="true" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
        <path clip-rule="evenodd" fill-rule="evenodd" d="M2 4.75A.75.75 0 012.75 4h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 4.75zm0 10.5a.75.75 0 01.75-.75h7.5a.75.75 0 010 1.5h-7.5a.75.75 0 01-.75-.75zM2 10a.75.75 0 01.75-.75h14.5a.75.75 0 010 1.5H2.75A.75.75 0 012 10z"></path>
      </svg>
    </button>
    <%= link_to root_path, class: "btn btn-ghost text-xl" do %>
      MyApp
    <% end %>
  </div>

  <div class="navbar-end">
    <ul class="menu menu-horizontal px-1 items-center gap-1">
      <% if authenticated? %>
        <li>
          <%= link_to "Messages (#{Current.user.messages.count})", messages_path %>
        </li>
        <li>
          <%= button_to session_path, method: :delete, class: "flex items-center gap-2" do %>
            <%= avatar_for(Current.user) %>
            <span>Sign out</span>
          <% end %>
        </li>
      <% else %>
        <li>
          <%= link_to "Sign in", new_session_path %>
        </li>
      <% end %>
    </ul>

    <div data-controller="theme" class="dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-ghost btn-circle">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
        </svg>
      </div>
      <ul tabindex="-1" class="menu menu-sm dropdown-content bg-base-100 rounded-box z-1 mt-3 w-36 p-2 shadow">
        <li><button data-action="theme#switch" data-theme="light">Light</button></li>
        <li><button data-action="theme#switch" data-theme="dark">Dark</button></li>
        <li><button data-action="theme#switch" data-theme="terminal">Terminal</button></li>
      </ul>
    </div>
  </div>
</header>
