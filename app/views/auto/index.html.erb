<div class="w-full">
  <% if notice = flash[:notice] %>
    <div role="alert" class="alert alert-success mb-5" id="notice" data-controller="toast">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex items-center justify-between mb-4">
    <h1 class="font-bold text-2xl"><%= controller_model.model_name.human.pluralize %> <span class="badge badge-sm bg-base-300 text-base-content border-0 ml-1"><%= resources.size %></span></h1>
    <% if authenticated? %>
      <%= link_to url_for(action: :new), class: "btn btn-primary btn-sm" do %>
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path clip-rule="evenodd" fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" />
        </svg>
        New <%= controller_model.model_name.human.downcase %>
      <% end %>
    <% end %>
  </div>

  <%= render "table", model: controller_model, records: resources, attrs: permitted_attributes %>
</div>
