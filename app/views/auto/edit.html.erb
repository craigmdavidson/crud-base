<div class="w-full">
  <div class="flex items-center justify-between mb-4">
    <%= link_to url_for(action: :show, id: resource), class: "btn btn-ghost btn-sm rounded-2xl" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    <% end %>
    <% if authenticated? %>
      <%= button_to "Delete", url_for(action: :destroy, id: resource), method: :delete, class: "btn btn-outline btn-error btn-sm rounded-2xl", data: { turbo_confirm: "Are you sure?" } %>
    <% end %>
  </div>
  <% if resource.respond_to?(:name) && resource.name.present? %>
    <h2 class="text-sm font-semibold text-base-content/60 uppercase tracking-wide">Edit <%= controller_model.model_name.human %></h2>
    <h1 class="font-bold text-2xl mb-6"><%= resource.name %></h1>
  <% else %>
    <h1 class="font-bold text-2xl mb-6">Edit <%= controller_model.model_name.human.downcase %></h1>
  <% end %>
  <div class="panel">
    <%= render "form", resource: resource %>
  </div>
</div>
