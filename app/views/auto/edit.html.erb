<div class="w-full">
  <div class="flex items-center justify-between mb-4">
    <%= link_to url_for(action: :show, id: resource), class: "btn btn-ghost btn-sm rounded-2xl" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    <% end %>
    <% if authenticated? %>
      <%= button_to "Delete", url_for(action: :destroy, id: resource), method: :delete, class: "btn btn-error btn-sm rounded-2xl", data: { turbo_confirm: "Are you sure?" } %>
    <% end %>
  </div>
  <h1 class="font-bold text-2xl mb-4">Edit <%= controller_model.model_name.human.downcase %></h1>
  <%= render "form", resource: resource %>
</div>
