<div class="w-full">
  <% if notice = flash[:notice] %>
    <div role="alert" class="alert alert-success mb-5" id="notice" data-controller="toast">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex items-center justify-between mb-4">
    <%= link_to url_for(action: :index), class: "btn btn-ghost btn-sm rounded-2xl" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    <% end %>
    <div class="flex items-center gap-2">
      <% if authenticated? %>
        <%= link_to url_for(action: :edit, id: resource), class: "btn btn-primary btn-sm rounded-2xl" do %>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L6.832 19.82a4.5 4.5 0 01-1.897 1.13l-2.685.8.8-2.685a4.5 4.5 0 011.13-1.897L16.863 4.487zm0 0L19.5 7.125" /></svg>
          Edit
        <% end %>
        <%= button_to "Delete", url_for(action: :destroy, id: resource), method: :delete, class: "btn btn-outline btn-error btn-sm rounded-2xl", data: { turbo_confirm: "Are you sure?" } %>
      <% end %>
    </div>
  </div>
  <% if resource.respond_to?(:name) && resource.name.present? %>
    <h2 class="text-xs font-normal text-base-content/60 uppercase tracking-wide"><%= controller_model.model_name.human %></h2>
    <h1 class="font-bold text-2xl mb-6"><%= resource.name %></h1>
  <% else %>
    <h1 class="font-bold text-2xl mb-6"><%= controller_model.model_name.human %></h1>
  <% end %>

  <% has_many_assocs = controller_model.reflect_on_all_associations(:has_many) %>
  <% has_details_tab = controller.class.key_attributes.present? %>

  <% if has_details_tab %>
    <%= render "details", attrs: controller.class.key_attributes, cols: controller.class.key_attributes.size %>
  <% else %>
    <%= render "details", cols: 2 %>
  <% end %>

  <% if has_many_assocs.any? || has_details_tab %>
    <div class="mt-8" data-controller="tabs">
      <div class="border-b border-base-300 mb-4">
        <div class="flex flex-wrap gap-1 -mb-px">
          <% if has_details_tab %>
            <button data-tabs-target="btn" data-action="tabs#switch"
                    class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-base-content/60 hover:text-base-content">
              Details
            </button>
          <% end %>
          <% has_many_assocs.each do |assoc| %>
            <button data-tabs-target="btn" data-action="tabs#switch"
                    class="px-4 py-2 text-sm font-medium border-b-2 border-transparent text-base-content/60 hover:text-base-content">
              <%= assoc.klass.model_name.human.pluralize %> <span class="badge badge-sm bg-base-300 text-base-content border-0 ml-1"><%= resource.public_send(assoc.name).size %></span>
            </button>
          <% end %>
        </div>
      </div>

      <% if has_details_tab %>
        <div id="tab-details" data-tabs-target="panel" class="hidden pt-8">
          <%= render "details", cols: 2 %>
        </div>
      <% end %>

      <% has_many_assocs.each do |assoc| %>
        <%= render "child_tab", assoc: assoc, first: false %>
      <% end %>
    </div>
  <% end %>
</div>
