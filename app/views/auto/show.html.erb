<div class="w-full">
  <% if notice = flash[:notice] %>
    <div role="alert" class="alert alert-success mb-5" id="notice" data-controller="toast">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span><%= notice %></span>
    </div>
  <% end %>

  <div class="flex items-center justify-between mb-4">
    <%= link_to url_for(action: :index), class: "btn btn-ghost btn-sm rounded-2xl" do %>
      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      Back
    <% end %>
    <div class="flex items-center gap-2">
      <% if authenticated? %>
        <%= link_to "Edit", url_for(action: :edit, id: resource), class: "btn btn-primary btn-sm rounded-2xl" %>
        <%= button_to "Delete", url_for(action: :destroy, id: resource), method: :delete, class: "btn btn-outline btn-error btn-sm rounded-2xl", data: { turbo_confirm: "Are you sure?" } %>
      <% end %>
    </div>
  </div>
  <h1 class="font-bold text-2xl mb-4"><%= controller_model.model_name.human %></h1>

  <% belongs_to_keys = controller_model.reflect_on_all_associations(:belongs_to).reject(&:polymorphic?).index_by { |a| a.foreign_key.to_sym } %>
  <% polymorphic_keys = controller_model.reflect_on_all_associations(:belongs_to).select(&:polymorphic?).index_by { |a| a.foreign_key.to_sym } %>
  <% polymorphic_type_cols = polymorphic_keys.values.map { |a| :"#{a.name}_type" }.to_set %>
  <% permitted_attributes.reject { |a| polymorphic_type_cols.include?(a) }.each do |attr| %>
    <% assoc = belongs_to_keys[attr] %>
    <% poly_assoc = polymorphic_keys[attr] %>
    <% column = controller_model.columns_hash[attr.to_s] %>
    <div class="my-5">
      <% if assoc %>
        <% related = resource.public_send(assoc.name) %>
        <h2 class="text-sm font-semibold text-base-content/60 uppercase tracking-wide"><%= assoc.klass.model_name.human %></h2>
        <% if related %>
          <% display_method = %i[name title label].detect { |m| assoc.klass.method_defined?(m) || assoc.klass.column_names.include?(m.to_s) } || :id %>
          <p class="mt-1 text-sm"><%= link_to related.public_send(display_method), related, class: "link" %></p>
        <% else %>
          <p class="mt-1 text-sm text-base-content/50 italic">None</p>
        <% end %>
      <% elsif poly_assoc %>
        <% related = resource.public_send(poly_assoc.name) %>
        <h2 class="text-sm font-semibold text-base-content/60 uppercase tracking-wide"><%= poly_assoc.name.to_s.humanize %></h2>
        <% if related %>
          <% display_method = %i[name title label].detect { |m| related.class.method_defined?(m) || related.class.column_names.include?(m.to_s) } || :id %>
          <p class="mt-1 text-sm"><%= link_to related.public_send(display_method), related, class: "link" %></p>
        <% else %>
          <p class="mt-1 text-sm text-base-content/50 italic">None</p>
        <% end %>
      <% else %>
        <h2 class="text-sm font-semibold text-base-content/60 uppercase tracking-wide"><%= controller_model.human_attribute_name(attr) %></h2>
        <% value = resource.public_send(attr) %>
        <% if column&.type == :text %>
          <div class="mt-1 text-sm whitespace-pre-wrap"><%= value %></div>
        <% else %>
          <p class="mt-1 text-sm"><%= value %></p>
        <% end %>
      <% end %>
    </div>
  <% end %>

  <% has_many_assocs = controller_model.reflect_on_all_associations(:has_many) %>
  <% if has_many_assocs.any? %>
    <div class="divider my-8"></div>

    <div class="border-b border-base-300 mb-4">
      <div class="flex flex-wrap gap-1 -mb-px">
        <% has_many_assocs.each_with_index do |assoc, i| %>
          <button onclick="document.querySelectorAll('[data-tab-panel]').forEach(p=>p.classList.add('hidden'));document.querySelectorAll('[data-tab-btn]').forEach(t=>{t.classList.remove('border-base-content','text-base-content');t.classList.add('border-transparent','text-base-content/60')});document.getElementById('tab-<%= assoc.name %>').classList.remove('hidden');this.classList.add('border-base-content','text-base-content');this.classList.remove('border-transparent','text-base-content/60')"
                  data-tab-btn
                  class="px-4 py-2 text-sm font-medium border-b-2 <%= i == 0 ? 'border-base-content text-base-content' : 'border-transparent text-base-content/60 hover:text-base-content' %>">
            <%= assoc.klass.model_name.human.pluralize %> <span class="badge badge-sm bg-base-300 text-base-content border-0 ml-1"><%= resource.public_send(assoc.name).size %></span>
          </button>
        <% end %>
      </div>
    </div>

    <% has_many_assocs.each_with_index do |assoc, i| %>
      <%= render "child_tab", assoc: assoc, first: i == 0 %>
    <% end %>
  <% end %>
</div>
