<%= form_with model: resource, url: (resource.persisted? ? url_for(action: :update, id: resource) : url_for(action: :create)), class: "contents" do |form| %>
  <%= hidden_field_tag :inline, 1 if params[:inline].present? %>
  <% if resource.errors.any? %>
    <div role="alert" class="alert alert-error mt-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
      <div>
        <h2><%= pluralize(resource.errors.count, "error") %> prohibited this <%= controller_model.model_name.human.downcase %> from being saved:</h2>
        <ul class="list-disc ml-5 mt-2">
          <% resource.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <% belongs_to_keys = controller_model.reflect_on_all_associations(:belongs_to).reject(&:polymorphic?).index_by { |a| a.foreign_key.to_sym } %>
  <% polymorphic_type_cols = controller_model.reflect_on_all_associations(:belongs_to).select(&:polymorphic?).map { |a| :"#{a.name}_type" }.to_set %>
  <% polymorphic_id_cols = controller_model.reflect_on_all_associations(:belongs_to).select(&:polymorphic?).map { |a| a.foreign_key.to_sym }.to_set %>
  <% permitted_attributes.reject { |a| polymorphic_type_cols.include?(a) || polymorphic_id_cols.include?(a) }.each do |attr| %>
    <% assoc = belongs_to_keys[attr] %>
    <div class="my-5">
      <% if assoc %>
        <% display_method = %i[name title label].detect { |m| assoc.klass.method_defined?(m) || assoc.klass.column_names.include?(m.to_s) } || :id %>
        <% new_url = url_for(controller: "/#{assoc.klass.model_name.route_key}", action: :new, inline: 1) rescue nil %>
        <div <%= "data-controller=nested-new data-nested-new-url-value=#{new_url}" if new_url %>>
          <fieldset class="fieldset">
            <legend class="fieldset-legend"><%= controller_model.human_attribute_name(assoc.name) %></legend>
            <div class="flex gap-2">
              <%= form.collection_select assoc.foreign_key, assoc.klass.all, :id, display_method, { prompt: "Select #{assoc.klass.model_name.human.downcase}" }, class: "select w-full", data: { nested_new_target: "select" } %>
              <% if new_url %>
                <button type="button" data-action="nested-new#open" class="btn btn-primary shrink-0">+</button>
              <% end %>
            </div>
          </fieldset>
          <% if new_url %>
            <dialog data-nested-new-target="dialog" data-action="close->nested-new#dialogClosed" class="modal">
              <div class="modal-box">
                <div class="flex justify-between items-center mb-4">
                  <h3 class="font-bold text-lg">New <%= assoc.klass.model_name.human.downcase %></h3>
                  <button type="button" data-action="nested-new#close" class="btn btn-sm btn-circle btn-ghost" aria-label="Close">✕</button>
                </div>
                <turbo-frame id="inline_new_<%= assoc.name %>" data-nested-new-target="frame" data-action="turbo:frame-load->nested-new#handleFrameLoad">
                </turbo-frame>
              </div>
              <div class="modal-backdrop" data-action="click->nested-new#close"></div>
            </dialog>
          <% end %>
        </div>
      <% else %>
        <%= auto_field(form, attr) %>
      <% end %>
    </div>
  <% end %>

  <div class="flex justify-end mt-4">
    <button type="submit" class="btn btn-primary rounded-2xl">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
      <%= resource.persisted? ? "Update" : "Create" %> <%= controller_model.model_name.human %>
    </button>
  </div>
<% end %>
