<% records ||= [] %>
<% attrs ||= [] %>
<% parent ||= nil %>
<% unless defined?(new_path) && new_path %>
  <% new_path = parent ? (polymorphic_url([:new, parent, model.model_name.singular.to_sym]) rescue nil) : nil %>
<% end %>
<% belongs_to_keys = model.reflect_on_all_associations(:belongs_to).index_by { |a| a.foreign_key.to_sym } %>

<div class="bg-white relative shadow-md sm:rounded-lg overflow-hidden">
  <div class="flex flex-col md:flex-row items-center justify-between space-y-3 md:space-y-0 md:space-x-4 p-4">
    <h3 class="font-semibold text-gray-900"><%= model.model_name.human.pluralize %></h3>
    <% if authenticated? && new_path %>
      <%= link_to new_path, class: "flex items-center justify-center text-white bg-blue-600 hover:bg-blue-500 font-medium rounded-lg text-sm px-4 py-2" do %>
        <svg class="h-3.5 w-3.5 mr-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path clip-rule="evenodd" fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" />
        </svg>
        New <%= model.model_name.human.downcase %>
      <% end %>
    <% end %>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm text-left text-gray-500">
      <thead class="text-xs text-gray-700 uppercase bg-gray-50">
        <tr>
          <% attrs.each do |attr| %>
            <% assoc = belongs_to_keys[attr] %>
            <th scope="col" class="px-4 py-3"><%= assoc ? assoc.klass.model_name.human : model.human_attribute_name(attr) %></th>
          <% end %>
        </tr>
      </thead>
      <tbody>
        <% records.each do |record| %>
          <% record_path = (polymorphic_path([parent, record]) rescue polymorphic_path(record)) %>
          <tr class="border-b hover:bg-gray-100 cursor-pointer" onclick="Turbo.visit('<%= record_path %>')">
            <% attrs.each_with_index do |attr, i| %>
              <% assoc = belongs_to_keys[attr] %>
              <% if i == 0 %>
                <th scope="row" class="px-4 py-3 font-medium text-gray-900 whitespace-nowrap"><%= record.public_send(attr) %></th>
              <% elsif assoc %>
                <% related = record.public_send(assoc.name) %>
                <% display_method = %i[name title label].detect { |m| assoc.klass.method_defined?(m) } || :id %>
                <td class="px-4 py-3"><%= related&.public_send(display_method) %></td>
              <% else %>
                <td class="px-4 py-3"><%= truncate(record.public_send(attr).to_s, length: 100) %></td>
              <% end %>
            <% end %>
          </tr>
        <% end %>
        <% if records.empty? %>
          <tr>
            <td colspan="<%= attrs.size %>" class="px-4 py-6 text-center text-gray-400 italic">
              No <%= model.model_name.human.pluralize.downcase %> yet.
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
